{
  "name": "pokemonpgc-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently --names \"frontend,api\" --prefix-colors \"cyan,yellow\" \"npm run dev:client --workspace=frontend\" \"npm run dev:api --workspace=frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev:api --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
